---
const baseUrl = 'https://github.com/decoherance/fivex-marketing/releases/download/assets';

const screenshots = [
  { src: `${baseUrl}/screenshot-dashboard.png`, alt: 'FiveX Strong dashboard screen' },
  { src: `${baseUrl}/screenshot-program.png`, alt: 'FiveX Strong program selection screen' },
  { src: `${baseUrl}/screenshot-exercise-list.png`, alt: 'FiveX Strong exercise list screen' },
  { src: `${baseUrl}/screenshot-workout.png`, alt: 'FiveX Strong active workout screen' },
  { src: `${baseUrl}/screenshot-track-progress.png`, alt: 'FiveX Strong progress tracking screen' },
  { src: `${baseUrl}/screenshot-progression.png`, alt: 'FiveX Strong progression overview screen' },
  { src: `${baseUrl}/screenshot-history.png`, alt: 'FiveX Strong workout history screen' },
  { src: `${baseUrl}/screenshot-pr.png`, alt: 'FiveX Strong personal records screen' },
];
---

<section id="screenshots" class="py-12 sm:py-24 px-6 max-w-7xl mx-auto animate-on-scroll">

  <!-- Section heading -->
  <h2 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight text-text-primary text-center">
    See it in action
  </h2>
  <p class="text-text-secondary text-lg mt-3 max-w-2xl mx-auto text-center">
    A look inside the app
  </p>

  <!-- Screenshot gallery -->
  <div class="mt-8 sm:mt-12 grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 justify-items-center">
    {screenshots.map((s) => (
      <img
        src={s.src}
        alt={s.alt}
        width="180"
        loading="lazy"
        class="w-full rounded-2xl border-2 border-border bg-surface-card cursor-pointer hover:border-brand-green transition-colors"
        data-screenshot
      />
    ))}
  </div>


</section>

<!-- Lightbox modal (outside section to avoid parent clipping) -->
<div id="screenshot-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm" aria-hidden="true">
  <button id="modal-close" class="absolute top-4 right-4 text-white/80 hover:text-white text-4xl leading-none cursor-pointer z-10" aria-label="Close">&times;</button>
  <button id="modal-prev" class="absolute left-4 text-white/80 hover:text-white text-5xl leading-none cursor-pointer" aria-label="Previous screenshot">&#8249;</button>
  <img id="modal-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] rounded-2xl" />
  <button id="modal-next" class="absolute right-4 text-white/80 hover:text-white text-5xl leading-none cursor-pointer" aria-label="Next screenshot">&#8250;</button>
</div>

<script>
  const modal = document.getElementById('screenshot-modal')!;
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const closeBtn = document.getElementById('modal-close')!;
  const prevBtn = document.getElementById('modal-prev')!;
  const nextBtn = document.getElementById('modal-next')!;
  const thumbs = [...document.querySelectorAll('[data-screenshot]')] as HTMLImageElement[];
  let currentIndex = 0;

  function showScreenshot(index: number) {
    currentIndex = (index + thumbs.length) % thumbs.length;
    modalImg.src = thumbs[currentIndex].src;
    modalImg.alt = thumbs[currentIndex].alt;
  }

  thumbs.forEach((img, i) => {
    img.addEventListener('click', () => {
      showScreenshot(i);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  prevBtn.addEventListener('click', () => showScreenshot(currentIndex - 1));
  nextBtn.addEventListener('click', () => showScreenshot(currentIndex + 1));
  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowLeft') showScreenshot(currentIndex - 1);
    if (e.key === 'ArrowRight') showScreenshot(currentIndex + 1);
  });
</script>
