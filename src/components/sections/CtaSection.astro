---
import CtaButton from '../CtaButton.astro';
---

<section id="cta" class="py-12 sm:py-24 lg:py-32 px-6 animate-on-scroll">

  <div class="max-w-3xl mx-auto text-center">

    <!-- Headline -->
    <h2 class="font-heading text-3xl sm:text-5xl font-bold tracking-tight text-text-primary">
      Start Training Now
    </h2>

    <!-- Trust signals -->
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 sm:gap-x-6 mt-4 sm:mt-6">
      <span class="flex items-center gap-1.5 text-brand-green text-base sm:text-lg font-medium">
        <svg class="w-4 h-4 sm:w-5 sm:h-5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Free forever
      </span>
      <span class="flex items-center gap-1.5 text-brand-green text-base sm:text-lg font-medium">
        <svg class="w-4 h-4 sm:w-5 sm:h-5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        No account
      </span>
      <span class="flex items-center gap-1.5 text-brand-green text-base sm:text-lg font-medium">
        <svg class="w-4 h-4 sm:w-5 sm:h-5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        No data leaves your phone
      </span>
    </div>
    <p class="text-text-muted text-sm sm:text-base mt-3 max-w-md mx-auto">
      Optional upgrades for extras like custom program slots and themes — nothing you need is locked away.
    </p>

    <!-- CTA -->
    <div class="mt-8">
      <CtaButton event="cta-bottom" size="lg" />
    </div>

  </div>

</section>
