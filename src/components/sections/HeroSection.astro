---
import { playStoreUrl } from '../../config';
---

<section class="relative min-h-screen overflow-hidden flex items-center">

  <!-- Gradient background layer (always visible) -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface-base via-[#0a1a0f] to-[#001a0d]" aria-hidden="true"></div>

  <!-- Video slot (hidden until video provided) -->
  <video class="absolute inset-0 w-full h-full object-cover hidden" autoplay muted loop playsinline aria-hidden="true">
    <!-- <source src="/hero-video.mp4" type="video/mp4"> -->
  </video>

  <!-- Content layer -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 sm:py-28 w-full">

    <!-- Two-column grid (desktop) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left column: text + CTA -->
      <div>
        <!-- Subtle green accent bar -->
        <div class="w-12 h-1 rounded-full bg-brand-green opacity-60 mb-6"></div>

        <!-- Uppercase label -->
        <p class="text-brand-green text-xs uppercase tracking-widest font-medium mb-4">Strength Training App</p>

        <!-- Headline -->
        <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-text-primary leading-tight">
          FiveX Strong
        </h1>

        <!-- Value proposition -->
        <p class="text-text-secondary text-lg sm:text-xl mt-6 max-w-lg leading-relaxed">
          The simplest way to run a 5x5 strength programme. Pick a workout, load the bar, and lift.
        </p>

        <!-- Google Play badge -->
        <a
          href={playStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get FiveX Strong on Google Play"
          class="inline-block mt-8"
        >
          <img
            src="/google-play-badge.png"
            alt="Get it on Google Play"
            width="200"
            height="59"
          />
        </a>
      </div>

      <!-- Right column: phone mockup (pure CSS, branded) -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative w-[160px] h-[180px] sm:w-[180px] sm:h-[200px] lg:w-[260px] lg:h-[520px] rounded-[2.5rem] border-4 border-border bg-surface-card shadow-[0_0_60px_rgba(0,230,118,0.12)] flex flex-col overflow-hidden mx-auto">

          <!-- Status bar mock -->
          <div class="h-6 lg:h-8 bg-surface-raised flex items-center justify-center">
            <div class="w-12 lg:w-16 h-3 lg:h-4 rounded-full bg-surface-base"></div>
          </div>

          <!-- Screen content -->
          <div class="flex-1 flex flex-col items-center justify-center gap-2 px-4">
            <span class="text-brand-green text-3xl lg:text-5xl font-heading font-bold">5X</span>
            <span class="text-text-secondary text-[10px] lg:text-xs text-center uppercase tracking-widest">FiveX Strong</span>
            <div class="w-6 lg:w-8 h-0.5 lg:h-1 rounded bg-brand-green opacity-60"></div>
          </div>

          <!-- Home bar -->
          <div class="h-6 lg:h-8 flex items-center justify-center">
            <div class="w-14 lg:w-20 h-0.5 lg:h-1 rounded-full bg-border"></div>
          </div>

        </div>
      </div>

    </div>
  </div>

</section>
