---
import { heroVideoUrl } from '../../config';
import CtaButton from '../CtaButton.astro';
---

<section class="relative min-h-screen overflow-hidden flex items-center">

  <!-- Gradient background layer (always visible) -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface-base via-[#0a1a0f] to-[#001a0d]" aria-hidden="true"></div>

  <!-- Video background (shown when heroVideoUrl is set) -->
  {heroVideoUrl && (
    <div class="absolute inset-0" aria-hidden="true">
      <video class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale" autoplay muted loop playsinline>
        <source src={heroVideoUrl} type="video/webm" />
      </video>
      <div class="absolute inset-0 bg-brand-green/15 mix-blend-multiply"></div>
    </div>
  )}

  <!-- Content layer -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 py-10 sm:py-28 w-full">

    <!-- Mobile: 3-row stack (headline → phone → CTA). Desktop: 2-column (text+CTA left, phone right) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-8 lg:gap-16 items-center">

      <!-- Headline + value prop (mobile: row 1, desktop: part of left column) -->
      <div class="text-center lg:text-right lg:order-1">
        <!-- Headline -->
        <h1 class="font-heading font-bold tracking-tight text-text-primary leading-tight">
          <span class="block text-3xl sm:text-5xl lg:text-6xl">Track Your Lifts.</span>
          <span class="block text-3xl sm:text-5xl lg:text-6xl mt-1 sm:mt-2">Keep Your Privacy.</span>
        </h1>

        <!-- App name -->
        <p class="font-heading font-bold text-text-primary text-2xl sm:text-3xl lg:text-4xl mt-4 sm:mt-6">FiveX Strong</p>
        <!-- Tagline -->
        <p class="text-brand-green text-xs lg:text-sm uppercase tracking-widest font-medium mt-1 sm:mt-2">FREE. PRIVATE. NO ACCOUNT.</p>

        <!-- Value proposition -->
        <p class="text-text-secondary text-base sm:text-xl lg:text-2xl mt-4 sm:mt-6 max-w-xl leading-relaxed mx-auto lg:mx-0 lg:ml-auto">
          The strength tracker that doesn't track you. Pick a program, load the bar, lift — your data never leaves your phone.
        </p>
        <p class="text-text-muted text-sm sm:text-base mt-2">For barbell, dumbbell, and calisthenics training.</p>

        <!-- Desktop CTA -->
        <div class="hidden lg:flex mt-10 justify-end">
          <CtaButton event="cta-hero-desktop" size="lg" />
        </div>
      </div>

      <!-- Phone mockup (mobile: row 2, desktop: right column) -->
      <div class="flex justify-center lg:order-2">
        <div class="relative w-[140px] sm:w-[220px] lg:w-[320px] rounded-[2rem] sm:rounded-[2.5rem] lg:rounded-[3rem] border-4 border-border bg-surface-card shadow-[0_0_60px_rgba(0,230,118,0.12)] flex flex-col overflow-hidden mx-auto">

          <!-- Status bar mock -->
          <div class="h-5 sm:h-6 lg:h-8 bg-surface-raised flex items-center justify-center">
            <div class="w-10 sm:w-12 lg:w-16 h-2.5 sm:h-3 lg:h-4 rounded-full bg-surface-base"></div>
          </div>

          <!-- Screenshot carousel -->
          <div class="relative overflow-hidden">
            {[
              'screenshot-dashboard',
              'screenshot-program',
              'screenshot-exercise-list',
              'screenshot-workout',
              'screenshot-track-progress',
              'screenshot-progression',
              'screenshot-history',
              'screenshot-pr',
            ].map((name, i) => (
              <img
                src={`https://github.com/decoherance/fivex-marketing/releases/download/assets/${name}.png`}
                alt={`FiveX Strong ${name.replace('screenshot-', '')} screen`}
                class:list={[
                  'w-full block transition-opacity duration-700',
                  i === 0 ? 'opacity-100' : 'absolute inset-0 opacity-0',
                ]}
                data-hero-slide
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            ))}
          </div>

          <!-- Home bar -->
          <div class="h-5 sm:h-6 lg:h-8 bg-surface-raised flex items-center justify-center">
            <div class="w-12 sm:w-14 lg:w-20 h-0.5 lg:h-1 rounded-full bg-border"></div>
          </div>

        </div>
      </div>

      <!-- CTA badge (mobile only: row 3, below phone) -->
      <div class="flex justify-center lg:hidden lg:order-3">
        <CtaButton event="cta-hero-mobile" size="lg" />
      </div>

    </div>
  </div>

</section>

<script>
  const slides = [...document.querySelectorAll('[data-hero-slide]')] as HTMLImageElement[];
  let current = 0;

  setInterval(() => {
    slides[current].classList.replace('opacity-100', 'opacity-0');
    current = (current + 1) % slides.length;
    slides[current].classList.replace('opacity-0', 'opacity-100');
  }, 3000);
</script>
