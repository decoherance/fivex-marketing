---
import Layers from "@lucide/astro/icons/layers";
import PenLine from "@lucide/astro/icons/pen-line";
import ChartBar from "@lucide/astro/icons/chart-bar";
import WifiOff from "@lucide/astro/icons/wifi-off";
import Crown from "@lucide/astro/icons/crown";

const features = [
  {
    icon: Layers,
    title: "Pre-built programs",
    description:
      "Jump straight into proven strength routines. No guesswork — just pick a program and start lifting.",
  },
  {
    icon: PenLine,
    title: "Build your own",
    description:
      "Create custom programs tailored to your goals. Choose exercises, sets, and reps that work for you.",
  },
  {
    icon: ChartBar,
    title: "Track your progress",
    description:
      "Every session logged automatically. See your history, track personal records, and watch your strength grow.",
  },
  {
    icon: WifiOff,
    title: "Works offline",
    description:
      "No Wi-Fi at the gym? No problem. Everything works offline — your data lives on your device.",
  },
];
---

<section id="features" class="py-12 sm:py-24 px-6 max-w-7xl mx-auto animate-on-scroll">
  <div class="text-center">
    <h2
      class="font-heading text-3xl sm:text-4xl font-bold tracking-tight text-text-primary"
    >
      What you get
    </h2>
    <p class="text-text-secondary text-lg sm:text-xl mt-3 max-w-2xl mx-auto">
      Everything you need to train stronger
    </p>
  </div>

  <div class="mt-8 sm:mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
    {
      features.map(({ icon: Icon, title, description }) => (
        <div class="bg-surface-card rounded-xl p-6 border border-border-subtle">
          <div class="flex items-center gap-2.5">
            <Icon size={22} class="text-brand-green shrink-0" />
            <h3 class="font-heading font-bold text-lg sm:text-xl text-text-primary">
              {title}
            </h3>
          </div>
          <p class="text-text-secondary text-sm sm:text-base mt-2 leading-relaxed">
            {description}
          </p>
        </div>
      ))
    }
  </div>

  <!-- Go Elite upsell -->
  <div class="mt-4 sm:mt-6 bg-surface-card rounded-xl p-6 border border-border-subtle text-center">
    <div class="flex items-center justify-center gap-2.5">
      <Crown size={22} class="text-brand-teal shrink-0" />
      <h3 class="font-heading font-bold text-lg sm:text-xl text-text-primary">Go Elite</h3>
      <span class="shrink-0 rounded-full bg-brand-teal/10 border border-brand-teal/30 px-3 py-0.5 font-heading font-bold text-xs text-brand-teal uppercase tracking-wider">Optional</span>
    </div>
    <ul class="text-text-secondary text-sm sm:text-base mt-3 leading-relaxed flex flex-wrap justify-center gap-x-5 gap-y-1">
      <li class="flex items-center gap-1.5">
        <span class="text-brand-teal">&#x2022;</span> More programs
      </li>
      <li class="flex items-center gap-1.5">
        <span class="text-brand-teal">&#x2022;</span> Extra custom program slots
      </li>
      <li class="flex items-center gap-1.5">
        <span class="text-brand-teal">&#x2022;</span> Elite Ultradark theme
      </li>
      <li class="flex items-center gap-1.5">
        <span class="text-brand-teal">&#x2022;</span> Support the developer
      </li>
    </ul>
  </div>
</section>
