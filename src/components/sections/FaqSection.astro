---
const faqs = [
  {
    question: "Is FiveX Strong really free?",
    answer: "Yes, completely free with no locked features. You get one custom program slot included — optional upgrades add extra slots, themes, and more.",
  },
  {
    question: "Do I need to create an account?",
    answer: "No. Just download and start lifting. No sign-up, no email required.",
  },
  {
    question: "I already use another workout tracker — why switch?",
    answer: "Most workout trackers profit from you twice: once through a monthly subscription, and again by collecting and selling your data. FiveX Strong is free, requires no account, and your data never leaves your phone. No one profits from your information — it's yours and yours alone.",
  },
  {
    question: "Does it work offline?",
    answer: "Yes. Everything runs on your device — no internet needed at the gym.",
  },
  {
    question: "What programs are included?",
    answer: "Several proven programs out of the box, with more being added. You can also build your own.",
  },
  {
    question: "Is my data private?",
    answer: "Your workout data stays on your phone. The app sends crash reports to help us fix bugs, and we may add anonymised usage analytics in the future to improve the app.",
  },
  {
    question: "Will I lose my data if I switch phones?",
    answer: "No. Your data is backed up automatically after each workout, and you can restore it on a new device easily.",
  },
  {
    question: "Is there a paid version?",
    answer: "There's an optional Elite upgrade that adds more programs, extra custom program slots, and an Ultradark theme. It's also a way to support the developer. Nothing you need to train is locked behind it.",
  },
  {
    question: "Is it available on iOS?",
    answer: "FiveX Strong is Android only for now. iOS is being considered for the future.",
  },
];
---

<section class="py-12 sm:py-24 px-6 animate-on-scroll">
  <div class="max-w-3xl mx-auto">

    <div class="text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight text-text-primary">
        Frequently Asked Questions
      </h2>
    </div>

    <div class="mt-8 sm:mt-12 space-y-3">
      {faqs.map(({ question, answer }) => (
        <details class="group border border-border-subtle rounded-lg bg-surface-card">
          <summary class="flex items-center justify-between cursor-pointer px-5 py-4 font-heading font-semibold text-base sm:text-xl text-text-primary select-none list-none [&::-webkit-details-marker]:hidden">
            <span>{question}</span>
            <svg class="w-5 h-5 shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
            </svg>
          </summary>
          <div class="px-5 pb-4">
            <p class="text-text-secondary text-sm sm:text-lg leading-relaxed">
              {answer}
            </p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
