---
import { playStoreUrl } from '../config';

interface Props {
  event: string;
  size?: 'sm' | 'md' | 'lg';
}

const { event, size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'gap-2.5 pl-5 pr-1.5 py-1.5 text-sm',
  md: 'gap-3 pl-6 pr-1.5 py-1.5 text-base',
  lg: 'gap-4 pl-8 pr-2 py-2 text-lg',
};

const badgeSizes = {
  sm: { width: 110, height: 32 },
  md: { width: 130, height: 38 },
  lg: { width: 160, height: 47 },
};
---

<a
  href={playStoreUrl}
  target="_blank"
  rel="noopener noreferrer"
  data-umami-event={event}
  class:list={[
    'inline-flex items-center rounded-full bg-gradient-to-br from-[#00c866] to-[#00c2a0] shadow-[0_0_24px_rgba(0,230,118,0.3)] transition hover:shadow-[0_0_32px_rgba(0,230,118,0.5)] hover:scale-[1.02] active:scale-[0.98]',
    sizeClasses[size],
  ]}
>
  <span class="font-heading font-bold text-white tracking-wide">Get FiveX Strong — Free</span>
  <img
    src="/google-play-badge.png"
    alt="Get it on Google Play"
    width={badgeSizes[size].width}
    height={badgeSizes[size].height}
    class="rounded-full"
  />
</a>
