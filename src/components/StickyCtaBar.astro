---
import CtaButton from './CtaButton.astro';
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-50 lg:hidden py-3 px-4 flex justify-center transition-opacity duration-300 opacity-0 pointer-events-none"
>
  <CtaButton event="cta-sticky" size="sm" />
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  const ctaSection = document.getElementById('cta');
  if (stickyCta) {
    let ctaVisible = false;
    const scrollThreshold = 300;

    function updateVisibility() {
      const scrolledPastThreshold = window.scrollY > scrollThreshold;
      const shouldShow = scrolledPastThreshold && !ctaVisible;
      stickyCta.classList.toggle('opacity-0', !shouldShow);
      stickyCta.classList.toggle('pointer-events-none', !shouldShow);
    }

    window.addEventListener('scroll', updateVisibility, { passive: true });

    if (ctaSection) {
      const ctaObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            ctaVisible = entry.isIntersecting;
            updateVisibility();
          });
        },
        { threshold: 0.1 }
      );
      ctaObserver.observe(ctaSection);
    }
  }
</script>
